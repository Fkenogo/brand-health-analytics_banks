rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bootstrap marker for first admin
    match /config/{docId} {
      allow read: if docId == 'bootstrap';
      allow create: if docId == 'bootstrap' && !exists(/databases/$(database)/documents/config/bootstrap);
      allow update, delete: if false;
    }

    // Allow invite lookup for onboarding before auth
    match /invites/{inviteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users collection: allow authenticated read/write (tighten later)
    match /users/{userId} {
      allow read, update, delete: if request.auth != null;
      allow create: if request.auth != null ||
        (request.resource.data.role == 'admin' &&
         request.resource.data.bootstrap == true &&
         !exists(/databases/$(database)/documents/config/bootstrap));
    }

    // Survey responses: public create, authenticated read
    match /responses/{responseId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Questionnaires: authenticated read/write
    match /questionnaires/{questionnaireId} {
      allow read, write: if request.auth != null;
    }

    // Panelists: admin reads/management, public survey can create/update profile/contact
    match /panelists/{panelistId} {
      allow read: if request.auth != null;
      allow create, update: if true;
      allow delete: if request.auth != null;
    }

    // Raffle entries from survey completion contact capture
    match /raffleEntries/{entryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Raffle campaign configuration and winners (admin module)
    match /raffleCampaigns/{campaignId} {
      allow read, write: if request.auth != null;
    }

    // Audit log: authenticated only
    match /audit/{auditId} {
      allow read, write: if request.auth != null;
    }

    // AI strategy advisor usage and cache
    match /aiStrategyUsage/{docId} {
      allow read, write: if request.auth != null;
    }

    match /aiStrategyCache/{docId} {
      allow read, write: if request.auth != null;
    }

    match /aiStrategyBriefs/{docId} {
      allow read, write: if request.auth != null;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
